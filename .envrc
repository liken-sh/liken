# direnv sources this file with bash whenever you cd into the repo; it is
# never executed directly, so a shebang would be wrong. The directive below
# tells shellcheck which dialect to lint it as.
# shellcheck shell=bash

source_env_if_exists .envrc.private

# Terraform's github provider (liken.sh/terraform.tf) authenticates
# with the same login the gh CLI already holds; minting the token
# here keeps a second long-lived credential out of .envrc.private.
GITHUB_TOKEN="$(gh auth token 2>/dev/null || true)"
export GITHUB_TOKEN
