# This is the Cluster manifest: the document that describes what
# your machines form together. Everything here is a fact that the
# whole fleet must agree on. This is why it lives in one document,
# instead of being repeated across the machine manifests. The same
# file travels in every machine's image. Once the cluster is up, it
# becomes a real resource there: `kubectl get clusters` answers "what
# is this fleet?", and editing that resource is how the fleet
# changes from then on.
#
# The join token is not here on purpose. This spec carries topology.
# Secrets travel in the identity directory that `liken mint` creates
# beside this file.
apiVersion: liken.sh/v1alpha1
kind: Cluster
metadata:
  name: {{ .ClusterName }}
spec:
  # These are the machines that run control planes, listed by machine
  # name. A machine finds its own role by looking for its own name
  # here: listed means leader, absent means follower. One name means
  # the cluster's state lives in sqlite on that machine. More than
  # one name means embedded etcd, whose majority quorum needs an odd
  # member count. The first name is the founding leader. It
  # initializes the cluster, and every other leader joins through it.
  leaders: [{{ range $i, $l := .Leaders }}{{ if $i }}, {{ end }}{{ $l }}{{ end }}]

  # This is where followers make first contact: the founding
  # leader's fixed address. This endpoint matters only for first
  # contact. After joining, every machine learns every leader. So a
  # deployment that wants this endpoint to survive its first leader
  # can point a DNS name or virtual IP here instead.
  endpoint: {{ .Endpoint }}

  network:
    # This is the subnet the machines use for Kubernetes traffic. A
    # machine may have several interfaces. The interface whose
    # address falls inside this subnet carries cluster traffic.
    nodeCIDR: {{ .NodeCIDR }}

    # This is the cluster's internal address plan. These values are
    # the defaults, written out instead of assumed, because every
    # machine must agree on them, and they cannot change once the
    # cluster exists. Pod addresses come from clusterCIDR, service
    # addresses come from serviceCIDR, and clusterDNS (inside
    # serviceCIDR) is the address that every pod's resolv.conf points
    # at.
    clusterCIDR: 10.42.0.0/16
    serviceCIDR: 10.43.0.0/16
    clusterDNS: 10.43.0.10
    clusterDomain: cluster.local

  time:
    # This is where the leaders get their time. Followers sync their
    # time from the leaders themselves. Declaring an upstream is your
    # choice; the OS never sets a default.
    upstreams: [{{ range $i, $u := .Upstreams }}{{ if $i }}, {{ end }}{{ $u }}{{ end }}]
{{ if .Features }}
  # These are your opt-ins from liken's feature vocabulary. liken
  # disables the bundled components by default. Naming one here is
  # the declaration that turns it back on ({} is a feature's empty
  # configuration).
  features:
{{- range .Features }}
    {{ . }}: {}
{{- end }}
{{- else }}
  # liken disables Kubernetes' bundled components by default. Opting
  # in is a declaration here. The vocabulary: traefik, servicelb,
  # metrics-server, iscsi, nfs, each with {} for its configuration.
  #
  # features:
  #   metrics-server: {}
{{- end }}
{{ if .Source }}
  releases:
    # This is where release artifacts come from for over-the-network
    # updates. To move the fleet to a new version, add the release's
    # catalog entry (printed when it is published) and set
    # spec.version. These are live edits to the Cluster resource,
    # never an image rebuild.
    source: {{ .Source }}
{{- else }}
  # Over-the-network updates need a release channel to fetch from.
  # When you have one, declare it, and move the fleet by adding a
  # release's catalog entry (printed when it is published) and
  # setting spec.version. These are live edits to the Cluster
  # resource, never an image rebuild.
  #
  # releases:
  #   source: https://example.com/releases
{{- end }}
