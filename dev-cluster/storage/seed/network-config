# The storage server's two networks, the same two jobs every lab
# machine has (see dev-cluster/Makefile): an uplink for reaching the
# outside world, and the cluster segment where the fleet lives.
# Interfaces are matched by MAC address, the one identity QEMU pins
# regardless of how the guest's kernel names its devices.
version: 2
ethernets:
  # The uplink: QEMU's user-mode network, with its built-in DHCP.
  # The server needs it exactly once, to install its packages on
  # first boot; user-mode NAT is private to this guest, so nothing
  # here reaches the fleet.
  uplink:
    match:
      macaddress: "52:54:00:4c:4b:10"
    set-name: uplink
    dhcp4: true
  # The cluster segment: the multicast wire the fleet speaks
  # Kubernetes over. Static, like every address on it — the segment
  # has no DHCP, deliberately. .100 sits well clear of the machines,
  # which count up from .1; this is the address the lab's exports
  # and targets are reached at.
  cluster:
    match:
      macaddress: "52:54:00:4c:4c:10"
    set-name: cluster
    dhcp4: false
    addresses: [10.10.0.100/24]
