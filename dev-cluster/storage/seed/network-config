# The storage server's two networks, with the same two jobs that
# every lab machine has (see dev-cluster/Makefile): an uplink for
# reaching the outside world, and the cluster segment where the
# fleet lives. The config matches interfaces by MAC address, the one
# identity that QEMU pins, regardless of how the guest's kernel names
# its devices.
version: 2
ethernets:
  # The uplink: QEMU's user-mode network, with its built-in DHCP.
  # The server needs this network exactly once, to install its
  # packages on first boot. User-mode NAT is private to this guest,
  # so nothing here reaches the fleet.
  uplink:
    match:
      macaddress: "52:54:00:4c:4b:10"
    set-name: uplink
    dhcp4: true
  # The cluster segment: the multicast wire that the fleet speaks
  # Kubernetes over. This address is static, like every address on
  # the segment, because the segment has no DHCP on purpose. .100
  # sits well clear of the machines, which count up from .1. This is
  # the address where the lab's exports and targets can be reached.
  cluster:
    match:
      macaddress: "52:54:00:4c:4c:10"
    set-name: cluster
    dhcp4: false
    addresses: [10.10.0.100/24]
